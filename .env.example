# ===========================================
# WP Launcher - Environment Configuration
# ===========================================
# Copy this file to .env and adjust values

# Network Configuration
APP_HOST=192.168.1.100       # Your server's local IP address
APP_PORT=5000                # Web interface port

# Security
SECRET_KEY=                  # Auto-generated by install.sh, or set manually

# WordPress Defaults (used when creating new projects)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com
WP_LOCALE=en_US

# Optional: GitHub OAuth (for multi-developer features)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
