FROM wordpress:php8.5-apache

# Installer WP-CLI et autres outils
RUN apt-get update && apt-get install -y \
    default-mysql-client \
    wget \
    less \
    nano \
    unzip \
    sudo \
    acl \
    attr \
    && rm -rf /var/lib/apt/lists/*

# Installer WP-CLI
RUN curl -L https://github.com/wp-cli/wp-cli/releases/download/v2.8.1/wp-cli-2.8.1.phar -o /usr/local/bin/wp \
    && chmod +x /usr/local/bin/wp

# Copier le script d'entrée personnalisé
COPY docker-entrypoint-custom.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint-custom.sh

ENTRYPOINT ["docker-entrypoint-custom.sh"]
CMD ["apache2-foreground"]
